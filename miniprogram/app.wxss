/* app.wxss - Project Claw 全局样式 v2.0 */

/* ── 重置 ── */
page { background: #f5f5f7; font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif; }

/* ── 容器 ── */
.container { padding: 24rpx 28rpx 120rpx; min-height: 100vh; }

/* ── 通用卡片 ── */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,.06);
}

/* ── 价格标签 ── */
.price { color: #e94560; font-size: 44rpx; font-weight: 800; }
.price-unit { font-size: 26rpx; font-weight: 400; }

/* ── 标签 chip ── */
.tag {
  display: inline-block;
  background: #f0e6ea; color: #e94560;
  border-radius: 8rpx; padding: 6rpx 16rpx;
  font-size: 22rpx; margin: 4rpx;
}
.tag-blue  { background: #e6eef8; color: #1a6bc4; }
.tag-green { background: #e6f4ea; color: #2e7d32; }
.tag-gray  { background: #f5f5f5; color: #888; }

/* ── 状态颜色 ── */
.status-green  { color: #30d158; }
.status-blue   { color: #0a84ff; }
.status-orange { color: #ff9f0a; }
.status-red    { color: #ff3b5c; }
.status-gray   { color: #aaa; }

/* ── 分隔线 ── */
.divider { height: 1rpx; background: #f0f0f0; margin: 20rpx 0; }

/* ── 加载状态 ── */
.loading-wrap {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 80rpx 40rpx; gap: 20rpx;
}

/* ── 空状态 ── */
.empty-state {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 100rpx 40rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #aaa; text-align: center; line-height: 1.8; }

/* ── 节区标题 ── */
.section-title {
  font-size: 32rpx; font-weight: 700;
  color: #1a1a2e; margin-bottom: 16rpx;
}

/* ── 状态圆点 ── */
.dot-online  { display: inline-block; width: 14rpx; height: 14rpx; border-radius: 50%; background: #30d158; }
.dot-offline { display: inline-block; width: 14rpx; height: 14rpx; border-radius: 50%; background: #ff3b5c; }
