<!-- pages/merchant/merchant.wxml -->
<view class="container">

  <!-- 顶部商家卡片 -->
  <view class="merchant-hero">
    <view class="hero-left">
      <view class="avatar">🏪</view>
      <view class="hero-info">
        <text class="hero-name">{{profile.name || '我的店铺'}}</text>
        <view class="hero-id" bindtap="onCopyId" data-id="{{merchantId}}">
          <text class="id-text">{{merchantId}}</text>
          <text class="id-copy">复制</text>
        </view>
      </view>
    </view>
    <view class="hero-right">
      <view class="status-pill {{isOnline ? 'online' : 'offline'}}">
        <view class="status-dot"></view>
        <text>{{isOnline ? 'Agent在线' : '未连接'}}</text>
      </view>
    </view>
  </view>

  <!-- 实时数据罗盘 -->
  <view class="stats-row">
    <view class="stat-box">
      <text class="stat-val green">{{stats.online_merchants || 0}}</text>
      <text class="stat-label">在线商家</text>
    </view>
    <view class="stat-box">
      <text class="stat-val blue">{{totalNegotiations}}</text>
      <text class="stat-label">谈判次数</text>
    </view>
    <view class="stat-box">
      <text class="stat-val red">{{successRate}}%</text>
      <text class="stat-label">成交率</text>
    </view>
  </view>

  <!-- B端Agent策略设置 -->
  <view class="section-title">🧠 B端Agent谈判策略</view>
  <view class="card">
    <view class="profile-row">
      <text class="profile-label">底价 ¥{{profile.bottom_price}}</text>
      <slider min="5" max="100" value="{{profile.bottom_price}}" step="0.5"
        data-key="bottom_price" bindchange="onSliderChange" activeColor="#e94560" />
    </view>
    <view class="profile-row">
      <text class="profile-label">正常售价 ¥{{profile.normal_price}}</text>
      <slider min="5" max="200" value="{{profile.normal_price}}" step="0.5"
        data-key="normal_price" bindchange="onSliderChange" activeColor="#e94560" />
    </view>
    <view class="profile-row">
      <text class="profile-label">最大折扣 {{profile.max_discount_rate * 100}}%</text>
      <slider min="0" max="30" value="{{profile.max_discount_rate * 100}}" step="1"
        data-key="max_discount_rate" bindchange="onSliderChange" activeColor="#e94560" />
    </view>
    <view class="profile-row">
      <text class="profile-label">配送时效 {{profile.delivery_time_minutes}}分钟</text>
      <slider min="5" max="60" value="{{profile.delivery_time_minutes}}" step="1"
        data-key="delivery_time_minutes" bindchange="onSliderChange" activeColor="#e94560" />
    </view>
    <view class="profile-row">
      <text class="profile-label">品质评分 {{profile.quality_score * 100 | 0}}%</text>
      <slider min="0" max="100" value="{{profile.quality_score * 100}}" step="1"
        data-key="quality_score" bindchange="onSliderChange" activeColor="#e94560" />
    </view>
    <view class="toggle-row">
      <text class="toggle-label">营业状态</text>
      <switch checked="{{profile.is_open}}" bindchange="onToggleOpen" color="#30d158" />
    </view>
    <button class="save-btn" bindtap="onSaveProfile" loading="{{isLoading}}">
      💾 同步到云端Agent
    </button>
  </view>

  <!-- 商家ID管理 -->
  <view class="section-title">⚙️ 节点配置</view>
  <view class="card">
    <view class="config-row">
      <text class="config-label">商家节点ID</text>
      <view class="config-val-wrap">
        <text class="config-val">{{merchantId}}</text>
        <view class="config-edit-btn" bindtap="onChangeMerchantId">修改</view>
      </view>
    </view>
    <view class="config-row">
      <text class="config-label">Agent连接状态</text>
      <text class="config-val {{wsStatus === 'connected' ? 'green' : 'red'}}">
        {{wsStatus === 'connected' ? '✅ 已连接Railway' : '❌ 未连接'}}
      </text>
    </view>
    <view class="config-row">
      <text class="config-label">待处理意图</text>
      <text class="config-val">{{stats.pending_intents || 0}}</text>
    </view>
    <button class="refresh-btn-full" bindtap="onRefreshStats">↻ 刷新状态</button>
  </view>

  <!-- 启动说明 -->
  <view class="card tip-card">
    <text class="tip-title">📡 如何启动B端Agent</text>
    <text class="tip-text">在本地终端运行：\n.\start_edge.ps1\n\nAgent将自动连接Railway云端，接收C端砍价请求并自动报价。</text>
  </view>

</view>
