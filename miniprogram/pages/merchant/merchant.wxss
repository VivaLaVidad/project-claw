/* pages/merchant/merchant.wxss */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 32rpx;
}
.page-title { font-size: 48rpx; font-weight: 800; color: #1a1a2e; }
.online-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.online-badge.online  { background: #e6f4ea; color: #2e7d32; }
.online-badge.offline { background: #f5f5f5; color: #888; }

/* 统计卡片 */
.stats-card {
  background: linear-gradient(145deg, #1a1a2e 0%, #16213e 100%);
}
.stats-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.8);
  margin-bottom: 28rpx;
}
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 24rpx;
}
.stat-item {
  background: rgba(255,255,255,0.07);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}
.stat-value {
  font-size: 52rpx;
  font-weight: 800;
  color: #e94560;
  display: block;
}
.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 6rpx;
  display: block;
}
.refresh-row {
  text-align: center;
  color: rgba(255,255,255,0.4);
  font-size: 24rpx;
  padding-top: 8rpx;
}

/* 画像面板 */
.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.panel-title { font-size: 30rpx; font-weight: 600; color: #1a1a2e; }
.panel-arrow { font-size: 24rpx; color: #aaa; }

.profile-summary { margin-top: 16rpx; }
.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.summary-label { font-size: 26rpx; color: #888; }
.summary-value { font-size: 28rpx; font-weight: 600; color: #1a1a2e; }

/* 编辑表单 */
.edit-form { margin-top: 20rpx; }
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.form-label { font-size: 26rpx; color: #666; width: 180rpx; flex-shrink: 0; }
.form-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  text-align: right;
}

/* 商家 ID 卡片 */
.merchant-id-card { text-align: center; padding: 36rpx; }
.mid-label { font-size: 24rpx; color: #aaa; display: block; margin-bottom: 12rpx; }
.mid-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 12rpx;
  word-break: break-all;
}
.mid-hint { font-size: 22rpx; color: #aaa; display: block; }
