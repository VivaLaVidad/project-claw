/* pages/merchant/merchant.wxss */
.merchant-hero{background:linear-gradient(135deg,#1a1a2e,#16213e);border-radius:24rpx;padding:32rpx;display:flex;justify-content:space-between;align-items:center;margin-bottom:24rpx}
.hero-left{display:flex;align-items:center;gap:24rpx}
.avatar{font-size:72rpx;background:rgba(255,255,255,.1);width:96rpx;height:96rpx;border-radius:50%;display:flex;align-items:center;justify-content:center}
.hero-info{}
.hero-name{font-size:32rpx;font-weight:700;color:#fff;display:block;margin-bottom:8rpx}
.hero-id{display:flex;align-items:center;gap:12rpx}
.id-text{font-size:22rpx;color:rgba(255,255,255,.5)}
.id-copy{font-size:20rpx;color:#e94560;border:1rpx solid rgba(233,69,96,.4);border-radius:6rpx;padding:2rpx 8rpx}
.status-pill{display:flex;align-items:center;gap:8rpx;border-radius:20rpx;padding:10rpx 20rpx;font-size:22rpx}
.status-pill.online{background:rgba(48,209,88,.15);color:#30d158}
.status-pill.offline{background:rgba(255,59,92,.15);color:#ff3b5c}
.status-dot{width:12rpx;height:12rpx;border-radius:50%;background:currentColor}
.stats-row{display:flex;gap:16rpx;margin-bottom:28rpx}
.stat-box{flex:1;background:#fff;border-radius:16rpx;padding:24rpx;text-align:center;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06)}
.stat-val{font-size:48rpx;font-weight:800;display:block;line-height:1.2}
.stat-val.green{color:#30d158}
.stat-val.blue{color:#0a84ff}
.stat-val.red{color:#e94560}
.stat-label{font-size:22rpx;color:#aaa;margin-top:8rpx;display:block}
.section-title{font-size:28rpx;font-weight:700;color:#1a1a2e;margin-bottom:16rpx}
.profile-row{margin-bottom:20rpx}
.profile-label{font-size:24rpx;color:#555;display:block;margin-bottom:8rpx}
.toggle-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:20rpx}
.toggle-label{font-size:28rpx;color:#333;font-weight:500}
.save-btn{background:linear-gradient(135deg,#e94560,#c73652);color:#fff;border:none;border-radius:16rpx;padding:24rpx 0;font-size:28rpx;font-weight:600;margin-top:8rpx}
.save-btn::after{border:none}
.config-row{display:flex;justify-content:space-between;align-items:center;padding:16rpx 0;border-bottom:1rpx solid #f5f5f5}
.config-row:last-child{border-bottom:none}
.config-label{font-size:26rpx;color:#666}
.config-val-wrap{display:flex;align-items:center;gap:12rpx}
.config-val{font-size:26rpx;color:#333}
.config-val.green{color:#30d158}
.config-val.red{color:#ff3b5c}
.config-edit-btn{font-size:22rpx;color:#e94560;border:1rpx solid rgba(233,69,96,.4);border-radius:8rpx;padding:4rpx 12rpx}
.refresh-btn-full{background:#f5f5f5;color:#666;border:none;border-radius:12rpx;padding:20rpx 0;font-size:26rpx;margin-top:16rpx}
.refresh-btn-full::after{border:none}
.tip-card{background:#fffbf0;border:1rpx solid #ffe58f}
.tip-title{font-size:26rpx;font-weight:600;color:#8a6d00;display:block;margin-bottom:12rpx}
.tip-text{font-size:22rpx;color:#a87c00;line-height:1.8;display:block}
