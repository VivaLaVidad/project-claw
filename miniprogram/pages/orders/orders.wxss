/* pages/orders/orders.wxss */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 32rpx;
}
.page-title { font-size: 48rpx; font-weight: 800; color: #1a1a2e; }
.refresh-btn {
  background: #f0f0f0;
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #666;
}
.order-card { cursor: pointer; }
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.order-demand { font-size: 32rpx; font-weight: 600; color: #1a1a2e; flex: 1; }
.order-status {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}
.status-gray   { background: #f0f0f0; color: #888; }
.status-blue   { background: #e6eef8; color: #1a6bc4; }
.status-orange { background: #fff3e0; color: #e65100; }
.status-green  { background: #e6f4ea; color: #2e7d32; }
.status-red    { background: #fce8e8; color: #c62828; }
.order-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.meta-item { font-size: 24rpx; color: #aaa; }
.detail-section { padding-top: 16rpx; }
.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.detail-label { font-size: 24rpx; color: #aaa; }
.detail-value { font-size: 26rpx; color: #333; text-align: right; max-width: 60%; }
.detail-value.small { font-size: 20rpx; word-break: break-all; }
.detail-value.price { color: #e94560; font-weight: 700; font-size: 32rpx; }
