<!--语音对讲页面-->
<view class="container">
  <!-- 状态栏 -->
  <view class="status-bar">
    <view class="status-content">
      <view class="status-indicator" style="background: {{isConnected ? '#52c41a' : '#999'}}"></view>
      <text class="status-text">{{status}}</text>
    </view>
    <view class="recording-time" wx:if="{{isRecording}}">
      {{formatTime(recordingTime)}}
    </view>
  </view>

  <!-- 主要内容 -->
  <view class="main-content">
    <!-- 未连接状态 -->
    <view wx:if="{{!isConnected}}" class="state-container">
      <view class="state-icon">🎤</view>
      <text class="state-title">语音对讲</text>
      <text class="state-desc">点击下方按钮开始对讲</text>
      <view class="order-info">
        <text>订单: {{orderId}}</text>
      </view>
    </view>

    <!-- 连接中状态 -->
    <view wx:else class="state-container">
      <view class="pulse-container">
        <view class="pulse"></view>
        <view class="pulse"></view>
        <view class="pulse"></view>
      </view>
      <text class="state-title">对讲中</text>
      <text class="state-desc">请说话...</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button 
      wx:if="{{!isConnected}}" 
      class="btn-start" 
      bindtap="startVoiceChat"
    >
      启动对讲
    </button>
    <button 
      wx:else 
      class="btn-stop" 
      bindtap="stopVoiceChat"
    >
      结束对讲
    </button>
  </view>
</view>
