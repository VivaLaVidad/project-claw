<!-- pages/index/index.wxml v3.0 -->
<view class="container">

  <!-- 顶部 -->
  <view class="hero-bar">
    <view class="hero-brand">
      <text class="hero-logo">🦞</text>
      <view>
        <text class="hero-title">Project Claw</text>
        <text class="hero-sub">AI 智能买手</text>
      </view>
    </view>
    <view class="status-pill {{serverStatus === 'online' ? 'pill-online' : 'pill-offline'}}">
      <view class="pill-dot"></view>
      <text>{{serverStatus === 'online' ? '已连接' : '离线'}}</text>
    </view>
  </view>

  <!-- 输入卡片 -->
  <view class="search-card">
    <view class="input-row">
      <text class="input-icon">🛒</text>
      <input class="main-input" placeholder="我想要…（如：龙虾、牛肉面）"
        value="{{itemName}}" bindinput="onItemNameInput" maxlength="32" />
    </view>
    <view class="input-divider"></view>
    <view class="input-row">
      <text class="input-icon">💰</text>
      <input class="main-input" placeholder="预算上限（元）"
        value="{{expectedPrice}}" bindinput="onPriceInput" type="digit" maxlength="8" />
    </view>

    <!-- 主按钮 -->
    <button class="btn-main" bindtap="onAutoNegotiate"
      disabled="{{isLoading || autoNegotiating}}" loading="{{autoNegotiating}}">
      🤖 Agent 全自动砍价
    </button>
    <view class="btn-row">
      <button class="btn-sub" bindtap="onStartDialogue" disabled="{{isLoading}}">💬 手动谈判</button>
      <button class="btn-sub btn-sub-blue" bindtap="onBroadcastIntent" disabled="{{isLoading}}">📡 快速广播</button>
    </view>
  </view>

  <!-- Agent 谈判日志 -->
  <view wx:if="{{negotiationLog.length > 0}}" class="log-card">
    <view class="log-header"><text class="log-title">🧠 Agent 实时谈判过程</text></view>
    <view wx:for="{{negotiationLog}}" wx:key="time" class="log-row">
      <text class="log-badge log-{{item.type}}">{{item.type === 'deal' ? '✅' : item.type === 'warn' ? '⚠️' : '🤖'}}</text>
      <text class="log-text">{{item.text}}</text>
      <text class="log-time">{{item.time}}</text>
    </view>
  </view>

  <!-- C端画像 -->
  <view class="card">
    <view class="panel-header" bindtap="onToggleProfile">
      <text class="panel-title">⚙️ 我的偏好（影响Agent谈判策略）</text>
      <text class="panel-arrow">{{showProfilePanel ? '▲' : '▼'}}</text>
    </view>
    <block wx:if="{{showProfilePanel && profile}}">
      <view class="profile-item">
        <text class="profile-label">预算下限 ¥{{profile.budget_min}}</text>
        <slider min="5" max="50" value="{{profile.budget_min}}" step="1"
          data-key="budget_min" bindchange="onProfileChange" activeColor="#e94560" />
      </view>
      <view class="profile-item">
        <text class="profile-label">预算上限 ¥{{profile.budget_max}}</text>
        <slider min="10" max="200" value="{{profile.budget_max}}" step="1"
          data-key="budget_max" bindchange="onProfileChange" activeColor="#e94560" />
      </view>
      <view class="profile-item">
        <text class="profile-label">价格敏感度 {{profile.price_sensitivity * 100}}%</text>
        <slider min="0" max="100" value="{{profile.price_sensitivity * 100}}" step="5"
          data-key="price_sensitivity" bindchange="onProfileChange" activeColor="#e94560" />
      </view>
      <view class="profile-item">
        <text class="profile-label">时效要求 {{profile.time_urgency * 100}}%</text>
        <slider min="0" max="100" value="{{profile.time_urgency * 100}}" step="5"
          data-key="time_urgency" bindchange="onProfileChange" activeColor="#e94560" />
      </view>
    </block>
  </view>

  <!-- 报价列表 -->
  <view wx:if="{{recentOffers.length > 0}}">
    <view class="section-title">📦 商家报价（{{recentOffers.length}}个）</view>
    <view wx:for="{{recentOffers}}" wx:key="merchant_id" class="offer-card">
      <view class="offer-top">
        <view>
          <text class="offer-merchant">🏪 {{item.merchant_id}}</text>
          <text class="offer-desc">{{item.reply_text || '-'}}</text>
        </view>
        <text class="offer-price">¥{{item.final_price}}</text>
      </view>
      <view class="offer-tags">
        <text class="tag">评分 {{item.match_score ? item.match_score.toFixed(1) : '-'}}</text>
        <text class="tag tag-blue">{{item.eta_minutes || 20}}分钟</text>
        <text wx:for="{{item.offer_tags}}" wx:key="*this" wx:for-item="tag" class="tag tag-green">{{tag}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{recentOffers.length === 0 && negotiationLog.length === 0 && !isLoading}}" class="empty-state">
    <text class="empty-icon">🦞</text>
    <text class="empty-text">输入商品 + 预算\n让 AI 帮你砍最低价</text>
  </view>

</view>
