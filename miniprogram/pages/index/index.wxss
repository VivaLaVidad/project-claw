/* pages/index/index.wxss */
.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0 32rpx;
}
.header-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #1a1a2e;
  letter-spacing: -1rpx;
}
.server-status {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
}
.status-text { font-size: 22rpx; color: #666; }
.search-card {
  background: linear-gradient(145deg, #1a1a2e 0%, #16213e 100%);
  padding: 40rpx;
}
.card-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 12rpx;
  font-weight: 500;
}
.search-input {
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  color: #ffffff;
  font-size: 32rpx;
  width: 100%;
  box-sizing: border-box;
}
.action-row { display: flex; gap: 20rpx; margin-top: 28rpx; }
.btn-auto {
  width: 100%;
  background: linear-gradient(135deg, #30d158 0%, #34c759 100%);
  color: #000;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 20rpx rgba(48,209,88,0.4);
}
.btn-auto::after { border: none; }
.btn-half { flex: 1; font-size: 26rpx; padding: 22rpx 0; }
.btn-manual {
  background: rgba(255,255,255,0.12);
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.25);
  border-radius: 14rpx;
}
.btn-manual::after { border: none; }
.btn-broadcast {
  background: rgba(255,59,92,0.2);
  color: #ff6b8a;
  border: 1rpx solid rgba(255,59,92,0.35);
  border-radius: 14rpx;
}
.btn-broadcast::after { border: none; }
/* 谈判日志 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}
.log-card { padding: 20rpx 24rpx; }
.log-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 24rpx;
  line-height: 1.6;
}
.log-dot-text { font-size: 22rpx; flex-shrink: 0; margin-top: 2rpx; }
.log-text { flex: 1; color: #333; }
.log-row.agent .log-text { color: #0a84ff; }
.log-row.deal .log-text  { color: #30d158; font-weight: 600; }
.log-row.warn .log-text  { color: #ff9f0a; }
/* 画像面板 */
.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.panel-title { font-size: 28rpx; font-weight: 600; color: #1a1a2e; }
.panel-arrow { font-size: 24rpx; color: #aaa; }
.profile-row { margin-top: 20rpx; }
.profile-label { font-size: 24rpx; color: #666; display: block; margin-bottom: 8rpx; }
/* 报价卡片 */
.offer-card { padding: 28rpx; }
.offer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.offer-merchant { font-size: 28rpx; font-weight: 600; color: #1a1a2e; }
.offer-desc { font-size: 26rpx; color: #666; margin-bottom: 16rpx; line-height: 1.5; }
.offer-meta { display: flex; flex-wrap: wrap; gap: 8rpx; }
.price { color: #e94560; font-size: 40rpx; font-weight: 700; }
.price-unit { font-size: 24rpx; font-weight: 400; }
.tag {
  background: #f0e6ea; color: #e94560;
  border-radius: 8rpx; padding: 6rpx 16rpx;
  font-size: 22rpx;
}
.tag-blue { background: #e6eef8; color: #1a6bc4; }
.tag-green { background: #e6f4ea; color: #2e7d32; }
/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: #aaa;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #aaa; text-align: center; line-height: 1.8; }
