/* pages/index/index.wxss v3.0 */
.hero-bar{display:flex;justify-content:space-between;align-items:center;padding:24rpx 0 20rpx}
.hero-brand{display:flex;align-items:center;gap:16rpx}
.hero-logo{font-size:56rpx}
.hero-title{font-size:36rpx;font-weight:800;color:#1a1a2e;display:block}
.hero-sub{font-size:22rpx;color:#aaa;display:block}
.status-pill{display:flex;align-items:center;gap:8rpx;border-radius:20rpx;padding:10rpx 20rpx;font-size:22rpx}
.pill-online{background:rgba(48,209,88,.12);color:#30d158}
.pill-offline{background:rgba(255,59,92,.12);color:#ff3b5c}
.pill-dot{width:12rpx;height:12rpx;border-radius:50%;background:currentColor}

.search-card{background:#fff;border-radius:24rpx;padding:32rpx;margin-bottom:24rpx;box-shadow:0 4rpx 24rpx rgba(0,0,0,.08)}
.input-row{display:flex;align-items:center;gap:16rpx;padding:8rpx 0}
.input-icon{font-size:36rpx;width:44rpx;text-align:center}
.main-input{flex:1;font-size:30rpx;color:#1a1a2e;height:72rpx}
.input-divider{height:1rpx;background:#f5f5f5;margin:8rpx 0}
.btn-main{background:linear-gradient(135deg,#e94560,#c73652);color:#fff;border:none;border-radius:16rpx;padding:28rpx 0;font-size:30rpx;font-weight:700;margin-top:24rpx;width:100%}
.btn-main::after{border:none}
.btn-row{display:flex;gap:16rpx;margin-top:16rpx}
.btn-sub{flex:1;background:#f5f5f7;color:#555;border:none;border-radius:12rpx;padding:22rpx 0;font-size:26rpx;font-weight:500}
.btn-sub::after{border:none}
.btn-sub-blue{background:#eef4ff;color:#1a6bc4}

.log-card{background:#0d1117;border-radius:16rpx;padding:24rpx;margin-bottom:24rpx}
.log-header{margin-bottom:16rpx}
.log-title{font-size:26rpx;color:#58a6ff;font-weight:600}
.log-row{display:flex;align-items:flex-start;gap:12rpx;margin-bottom:12rpx}
.log-badge{font-size:24rpx;flex-shrink:0}
.log-text{font-size:24rpx;color:#c9d1d9;flex:1;line-height:1.6}
.log-time{font-size:20rpx;color:#484f58;flex-shrink:0}

.panel-header{display:flex;justify-content:space-between;align-items:center}
.panel-title{font-size:28rpx;font-weight:600;color:#1a1a2e}
.panel-arrow{font-size:24rpx;color:#aaa}
.profile-item{margin-top:16rpx}
.profile-label{font-size:24rpx;color:#666;display:block;margin-bottom:4rpx}

.section-title{font-size:28rpx;font-weight:700;color:#1a1a2e;margin-bottom:16rpx}
.offer-card{background:#fff;border-radius:20rpx;padding:28rpx;margin-bottom:16rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06)}
.offer-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16rpx}
.offer-merchant{font-size:28rpx;font-weight:600;color:#1a1a2e;display:block;margin-bottom:8rpx}
.offer-desc{font-size:24rpx;color:#888;display:block;line-height:1.6}
.offer-price{font-size:52rpx;font-weight:800;color:#e94560;flex-shrink:0}
.offer-tags{display:flex;flex-wrap:wrap;gap:10rpx}
.tag{font-size:22rpx;background:#f0e6ea;color:#e94560;border-radius:8rpx;padding:6rpx 14rpx}
.tag-blue{background:#eef4ff;color:#1a6bc4}
.tag-green{background:#e6f4ea;color:#2e7d32}

.empty-state{display:flex;flex-direction:column;align-items:center;padding:100rpx 40rpx}
.empty-icon{font-size:100rpx;margin-bottom:24rpx}
.empty-text{font-size:28rpx;color:#aaa;text-align:center;line-height:1.8}
