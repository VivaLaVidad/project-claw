/* app.wxss - Project Claw 全局样式 v3.0 深色工业风 */

page {
  background: #0f0c29;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #fff;
}

.container { padding: 24rpx 28rpx 140rpx; min-height: 100vh; }

/* ── 通用卡片 ── */
.card {
  background: rgba(255,255,255,.06);
  border: 1rpx solid rgba(255,255,255,.08);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

/* ── 价格 ── */
.price { color: #e94560; font-size: 44rpx; font-weight: 800; }

/* ── 标签 chip ── */
.tag { display: inline-block; background: rgba(233,69,96,.12); color: #e94560; border-radius: 8rpx; padding: 6rpx 16rpx; font-size: 22rpx; margin: 4rpx; }
.tag-blue  { background: rgba(91,163,245,.12); color: #5ba3f5; }
.tag-green { background: rgba(48,209,88,.12); color: #30d158; }
.tag-gray  { background: rgba(255,255,255,.06); color: rgba(255,255,255,.4); }

/* ── 状态颜色 ── */
.status-green  { color: #30d158; }
.status-blue   { color: #0a84ff; }
.status-orange { color: #ff9f0a; }
.status-red    { color: #ff3b5c; }
.status-gray   { color: rgba(255,255,255,.3); }

/* ── 颜色工具 ── */
.green { color: #30d158; }
.blue  { color: #5ba3f5; }
.red   { color: #e94560; }

/* ── 分隔线 ── */
.divider { height: 1rpx; background: rgba(255,255,255,.06); margin: 20rpx 0; }

/* ── 加载 ── */
.loading-wrap {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 80rpx 40rpx; gap: 20rpx;
}
.loading-text { font-size: 26rpx; color: rgba(255,255,255,.4); }
.spinner {
  width: 48rpx; height: 48rpx;
  border: 4rpx solid rgba(255,255,255,.1);
  border-top-color: #e94560;
  border-radius: 50%;
  animation: _spin .8s linear infinite;
}
@keyframes _spin { to { transform: rotate(360deg); } }

/* ── 空状态 ── */
.empty-state {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 100rpx 40rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: rgba(255,255,255,.3); text-align: center; line-height: 1.8; }

/* ── 节区标题 ── */
.section-title { font-size: 32rpx; font-weight: 700; color: #fff; margin-bottom: 16rpx; }

/* ── 圆点 ── */
.dot-online  { display: inline-block; width: 14rpx; height: 14rpx; border-radius: 50%; background: #30d158; }
.dot-offline { display: inline-block; width: 14rpx; height: 14rpx; border-radius: 50%; background: #ff3b5c; }
