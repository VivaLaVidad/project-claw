<!--首页 - 订单列表-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-content">
      <view class="greeting">
        <text class="greeting-text">欢迎回来</text>
        <text class="user-name">{{userInfo?.nickname || '用户'}}</text>
      </view>
      <view class="user-avatar" bindtap="showUserMenu">
        <image src="{{userInfo?.avatar || '/assets/default-avatar.png'}}" mode="aspectFill"></image>
      </view>
    </view>
  </view>

  <!-- 快速操作 -->
  <view class="quick-actions">
    <view class="action-btn" bindtap="createOrder">
      <view class="action-icon">➕</view>
      <text>新建订单</text>
    </view>
    <view class="action-btn" bindtap="loadOrders" data-refresh="true">
      <view class="action-icon">🔄</view>
      <text>刷新</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="orders-section">
    <view class="section-title">
      <text>我的订单</text>
      <text class="order-count">{{orders.length}}</text>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading && orders.length === 0}}" class="loading">
      <view class="spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{!loading && orders.length === 0}}" class="empty-state">
      <view class="empty-icon">📭</view>
      <text class="empty-text">暂无订单</text>
      <view class="empty-action">
        <button class="btn-primary" bindtap="createOrder">创建第一个订单</button>
      </view>
    </view>

    <!-- 订单列表 -->
    <view wx:else class="orders-list">
      <view wx:for="{{orders}}" wx:key="order_id" class="order-card" data-order-id="{{item.order_id}}">
        <!-- 订单头部 -->
        <view class="order-header">
          <view class="order-id">订单 #{{item.order_id}}</view>
          <view class="order-status" style="color: {{item.status === 'completed' ? '#52c41a' : '#faad14'}}">
            {{item.status === 'completed' ? '已完成' : '进行中'}}
          </view>
        </view>

        <!-- 订单内容 -->
        <view class="order-content">
          <view class="order-info">
            <text class="label">金额:</text>
            <text class="value">¥{{item.amount}}</text>
          </view>
          <view class="order-info">
            <text class="label">时间:</text>
            <text class="value">{{item.created_at}}</text>
          </view>
        </view>

        <!-- 订单操作 -->
        <view class="order-actions">
          <button class="btn-secondary" bindtap="viewOrderDetail" data-order-id="{{item.order_id}}">
            查看详情
          </button>
          <button class="btn-primary" bindtap="startVoiceChat" data-order-id="{{item.order_id}}">
            语音对讲
          </button>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{hasMore && orders.length > 0}}" class="load-more">
      <view wx:if="{{loading}}" class="spinner-small"></view>
      <text>{{loading ? '加载中...' : '上拉加载更多'}}</text>
    </view>
  </view>
</view>
