/**语音对讲页面样式*/

.container {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  color: white;
}

/* ==================== 状态栏 ==================== */

.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  background: rgba(0, 0, 0, 0.2);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.status-content {
  display: flex;
  align-items: center;
  gap: 8px;
}

.status-indicator {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  animation: pulse-indicator 1.5s ease-in-out infinite;
}

@keyframes pulse-indicator {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.status-text {
  font-size: 14px;
  font-weight: bold;
}

.recording-time {
  font-size: 16px;
  font-weight: bold;
  font-family: 'Courier New', monospace;
}

/* ==================== 主要内容 ==================== */

.main-content {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40px 20px;
}

.state-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-icon {
  font-size: 80px;
  margin-bottom: 20px;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20px); }
}

.state-title {
  font-size: 28px;
  font-weight: bold;
  margin-bottom: 12px;
}

.state-desc {
  font-size: 16px;
  opacity: 0.8;
  margin-bottom: 20px;
}

.order-info {
  background: rgba(255, 255, 255, 0.1);
  padding: 12px 20px;
  border-radius: 8px;
  font-size: 14px;
  margin-top: 20px;
}

/* ==================== 脉冲动画 ==================== */

.pulse-container {
  position: relative;
  width: 120px;
  height: 120px;
  margin-bottom: 20px;
}

.pulse {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 3px solid rgba(233, 69, 96, 0.6);
  border-radius: 50%;
  animation: pulse-animation 2s ease-out infinite;
}

.pulse:nth-child(1) {
  animation-delay: 0s;
}

.pulse:nth-child(2) {
  animation-delay: 0.6s;
}

.pulse:nth-child(3) {
  animation-delay: 1.2s;
}

@keyframes pulse-animation {
  0% {
    transform: scale(0.8);
    opacity: 1;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

/* ==================== 操作按钮 ==================== */

.action-buttons {
  padding: 20px;
  display: flex;
  gap: 12px;
}

.btn-start,
.btn-stop {
  flex: 1;
  padding: 16px;
  border-radius: 12px;
  font-size: 16px;
  font-weight: bold;
  border: none;
  transition: all 0.3s ease;
}

.btn-start {
  background: #52c41a;
  color: white;
}

.btn-start:active {
  background: #45a517;
  transform: scale(0.98);
}

.btn-stop {
  background: #e94560;
  color: white;
}

.btn-stop:active {
  background: #d63a52;
  transform: scale(0.98);
}
