/* Project Claw v14.3 - pages/history/history.wxss */

.page {
  min-height: 100vh;
  background: #f0f4f8;
  padding-bottom: 60rpx;
}

/* ── 顶部标题 ── */
.header {
  background: #0f172a;
  padding: 48rpx 32rpx 32rpx;
  margin-bottom: 24rpx;
}
.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #f1f5f9;
  margin-bottom: 8rpx;
}
.header-sub {
  font-size: 24rpx;
  color: #64748b;
}

/* ── 加载条 ── */
.loading-bar {
  background: #eff6ff;
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  color: #3b82f6;
  text-align: center;
  margin-bottom: 16rpx;
}

/* ── 空状态 ── */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  gap: 16rpx;
}
.empty-icon { font-size: 80rpx; }
.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #334155;
}
.empty-hint {
  font-size: 24rpx;
  color: #94a3b8;
}
.btn-home {
  margin-top: 16rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  height: 84rpx;
  padding: 0 56rpx;
  border: none;
}

/* ── 订单卡片 ── */
.order-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 0 24rpx 20rpx;
  display: flex;
  align-items: stretch;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.order-status-bar {
  width: 8rpx;
  flex-shrink: 0;
}
.bar-ok      { background: #22c55e; }
.bar-err     { background: #ef4444; }
.bar-pending { background: #f59e0b; }

.order-body {
  flex: 1;
  padding: 24rpx 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.order-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.order-item {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  flex: 1;
}
.order-price {
  font-size: 34rpx;
  font-weight: 800;
  color: #dc2626;
}
.order-price-empty {
  font-size: 24rpx;
  color: #94a3b8;
}

.order-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}
.meta-tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.tag-ok      { background: #dcfce7; color: #15803d; }
.tag-err     { background: #fee2e2; color: #dc2626; }
.tag-pending { background: #fef3c7; color: #92400e; }

.meta-merchant {
  font-size: 24rpx;
  color: #64748b;
}
.meta-offers {
  font-size: 22rpx;
  color: #94a3b8;
}

.order-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.order-time {
  font-size: 22rpx;
  color: #94a3b8;
}
.order-id {
  font-size: 20rpx;
  color: #cbd5e1;
  font-family: monospace;
}

.footer-space { height: 40rpx; }
