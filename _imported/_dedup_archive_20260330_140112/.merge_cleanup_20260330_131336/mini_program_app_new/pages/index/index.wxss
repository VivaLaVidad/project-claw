/* Project Claw v14.3 - pages/index/index.wxss (优化版) */

.page {
  min-height: 100vh;
  background: #f0f4f8;
  padding-bottom: 120rpx;
}

/* ── Hero 区 ── */
.hero {
  background: linear-gradient(160deg, #0f172a 0%, #1e3a5f 100%);
  padding: 60rpx 32rpx 48rpx;
  margin-bottom: 24rpx;
}
.hero-title {
  font-size: 52rpx;
  font-weight: 900;
  color: #f1f5f9;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}
.hero-sub {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}
.hero-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.dot-ok      { background: #22c55e; box-shadow: 0 0 10rpx #22c55e; }
.dot-err     { background: #ef4444; box-shadow: 0 0 10rpx #ef4444; }
.dot-pending { background: #94a3b8; }
.status-text {
  color: #94a3b8;
  font-size: 24rpx;
  flex: 1;
}
.merchant-badge {
  background: rgba(56,189,248,0.15);
  border: 1rpx solid rgba(56,189,248,0.4);
  border-radius: 20rpx;
  padding: 6rpx 20rpx;
  font-size: 22rpx;
  color: #38bdf8;
  font-weight: 600;
}
.geo-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}
.geo-text {
  font-size: 22rpx;
  color: #64748b;
}
.geo-change {
  font-size: 22rpx;
  color: #38bdf8;
}

/* ── 卡片 ── */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

/* ── 表单元素 ── */
.section-label {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 10rpx;
  margin-top: 24rpx;
  font-weight: 500;
}
.section-label:first-child { margin-top: 0; }
.required { color: #ef4444; margin-left: 4rpx; }

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1e293b;
  box-sizing: border-box;
}
.form-input-lg {
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.price-row {
  display: flex;
  align-items: center;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 14rpx;
  overflow: hidden;
}
.price-symbol {
  font-size: 36rpx;
  font-weight: 700;
  color: #dc2626;
  padding: 0 16rpx 0 24rpx;
  flex-shrink: 0;
}
.price-input {
  flex: 1;
  background: transparent;
  border: none;
  border-radius: 0;
  padding-left: 0;
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.form-textarea {
  width: 100%;
  min-height: 80rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1e293b;
  box-sizing: border-box;
  line-height: 1.6;
}

.form-row {
  display: flex;
  gap: 20rpx;
}
.form-col { flex: 1; }

/* ── 高级选项 ── */
.advanced-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f1f5f9;
  font-size: 24rpx;
  color: #94a3b8;
}
.toggle-arrow {
  font-size: 20rpx;
  color: #cbd5e1;
}

/* ── 快捷选品 ── */
.quick-scroll {
  width: 100%;
  white-space: nowrap;
}
.quick-list {
  display: inline-flex;
  gap: 14rpx;
  padding: 4rpx 2rpx 16rpx;
}
.quick-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  background: #f1f5f9;
  border: 2rpx solid #e2e8f0;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #475569;
  white-space: nowrap;
  flex-shrink: 0;
}
.quick-tag-active {
  background: #eff6ff;
  border-color: #3b82f6;
  color: #2563eb;
  font-weight: 600;
}

/* ── 按钮 ── */
.btn-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 0 24rpx 24rpx;
}
.btn-location {
  background: #ffffff;
  border: 2rpx solid #cbd5e1;
  color: #334155;
  font-size: 26rpx;
  border-radius: 18rpx;
  height: 80rpx;
}
.btn-submit {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 18rpx;
  height: 100rpx;
  border: none;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 28rpx rgba(37,99,235,0.4);
}
.btn-submit[disabled] {
  background: #94a3b8;
  box-shadow: none;
}

/* ── 底部 ── */
.footer {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 0 40rpx;
}
.footer-link {
  font-size: 24rpx;
  color: #64748b;
}
.footer-sep {
  font-size: 20rpx;
  color: #cbd5e1;
}
