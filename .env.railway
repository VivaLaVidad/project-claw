# Project Claw - Railway 环境变量配置
# 在 Railway Dashboard → Variables 中设置这些变量

# ─── 核心服务开关 ────────────────────────────────────────────────
# 生产环境启用账本（需配置 PostgreSQL）
LEDGER_ENABLED=1

# 生产环境启用清结算（需配置 PostgreSQL）
CLEARING_ENABLED=1

# 社交匹配功能（可选）
SOCIAL_ENABLED=0

# ─── 数据库（Railway 自动注入，无需手动填）────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/claw
# REDIS_URL=redis://user:password@host:6379/0

# ─── 账本/清结算数据库（可复用同一个 PostgreSQL）────────────────────
# LEDGER_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/claw
# CLEARING_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/claw

# ─── JWT 安全密钥（必须改！）───────────────────────────────────────
HUB_JWT_SECRET=your-strong-jwt-secret-change-in-prod-2026
HUB_JWT_EXPIRE_SEC=86400
HUB_MERCHANT_KEY=your-merchant-shared-key-change-in-prod

# ─── 微信小程序（必须填）──────────────────────────────────────────
WECHAT_APPID=wx1f7d608c84f6da6d
WECHAT_APPSECRET=your-wechat-appsecret

# ─── 微信支付 V3（启用分账时必须填）──────────────────────────────
WECHAT_MCH_ID=your-mch-id
WECHAT_API_V3_KEY=your-api-v3-key
# WECHAT_PRIVATE_KEY_PATH=/app/certs/apiclient_key.pem

# ─── 账本配置（默认值可不填）──────────────────────────────────────
LEDGER_ROUTING_FEE_RATIO=0.01
LEDGER_PLATFORM_PROFIT_RATIO=0.40
LEDGER_PROMOTER_PROFIT_RATIO=0.60
LEDGER_QUOTE_MIN_TOKEN=1

# ─── Hub 性能参数（默认值可不填）──────────────────────────────────
HUB_REQUEST_HARD_TIMEOUT_SEC=60
HUB_SNAPSHOT_TTL_SEC=600
HUB_EARLY_RETURN_SEC=4
HUB_RATE_LIMIT_PER_MIN=60

# ─── DeepSeek LLM API（edge_box 需要）──────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key
