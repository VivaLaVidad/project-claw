# Project Claw v14.0 - B端边缘盒子配置

# 商户 ID（唯一标识此龙虾盒子）
MERCHANT_ID=box-001

# 云端信令塔地址（ws:// 或 wss://）
# 若留空，则只运行本地微信接单，不连接云端
SIGNALING_URL=ws://your-server:8765

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-key-here

# 菜单 CSV 文件路径
MENU_CSV=menu.csv

# 收款码图片路径（商家微信收款码截图）
PAYMENT_QR=payment_qr.png

# 微信输入框坐标（根据手机分辨率调整）
INPUT_X=540
INPUT_Y=1800

# OCR 轮询间隔（秒）
POLL_INTERVAL=0.3

# 消息队列最大长度（队列满时丢弃最旧消息）
MESSAGE_QUEUE_MAX=200

# watchdog 检查间隔（秒）
WATCHDOG_INTERVAL=5

# 指标日志输出间隔（秒）
METRICS_LOG_INTERVAL=15

# LLM 单次调用超时（秒）
LLM_TIMEOUT_SEC=18

# 熔断阈值：连续失败次数达到后打开熔断
CB_FAILURE_THRESHOLD=3

# 熔断打开时长（秒）
CB_OPEN_SECONDS=60

# Android 设备序列号（多设备时填写，单设备留空）
# DEVICE_SERIAL=

# 无头配网 daemon 配置
CLAW_SETUP_AP_NAME=Claw-Setup
CLAW_SETUP_AP_PASSWORD=12345678
CLAW_WIFI_IFACE=wlan0
CLAW_SETUP_PORT=80
# 默认尝试 lobster_mvp.py，不存在时自动回退 edge_box/main.py
CLAW_MAIN_ENTRY=lobster_mvp.py
# systemd 主服务名（bootstrap 成功后重启）
CLAW_SERVICE_NAME=claw-edge.service
# 可选：LED 控制命令，接收参数 red_blink/green_solid/yellow_blink
# CLAW_LED_COMMAND=/usr/local/bin/claw_led
