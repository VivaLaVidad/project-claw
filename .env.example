# Project Claw 环境变量配置示例
# 复制此文件为 .env 并填入实际的值

# ═══════════════════════════════════════════════════════════════
# DeepSeek LLM 配置
# ═══════════════════════════════════════════════════════════════
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=15
DEEPSEEK_MAX_TOKENS=200
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_RETRIES=3

# ═══════════════════════════════════════════════════════════════
# OpenAI GPT-4o 配置（可选）
# ═══════════════════════════════════════════════════════════════
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-vision-preview

# ═══════════════════════════════════════════════════════════════
# 系统配置
# ═══════════════════════════════════════════════════════════════
SYSTEM_PROMPT=你是一个热情的店老板，回话简短接地气，叫人'兄弟'。
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════
# 本地记忆配置
# ═══════════════════════════════════════════════════════════════
LOCAL_MEMORY_ENABLED=true
LOCAL_MEMORY_DB_DIR=./claw_db
LOCAL_MEMORY_CSV=menu.csv
LOCAL_MEMORY_TOP_K=3
LOCAL_MEMORY_EMBED_MODEL=all-MiniLM-L6-v2

# ═══════════════════════════════════════════════════════════════
# OCR 配置
# ═══════════════════════════════════════════════════════════════
OCR_LANGUAGES=ch_sim,en
OCR_FAIL_MAX_RETRIES=3

# ═══════════════════════════════════════════════════════════════
# Redis 配置
# ═══════════════════════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TIMEOUT=5

# ═══════════════════════════════════════════════════════════════
# 数据库配置
# ═══════════════════════════════════════════════════════════════
AUDIT_DB_PATH=./audit.db
DLQ_DB_PATH=./dlq.db
AUDIT_SECRET_KEY=claw-audit-secret-key-change-in-production

# ═══════════════════════════════════════════════════════════════
# 服务器配置
# ═══════════════════════════════════════════════════════════════
API_HOST=0.0.0.0
API_PORT=8765
API_WORKERS=4
API_RELOAD=true

DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501

# ═══════════════════════════════════════════════════════════════
# 支付配置
# ═══════════════════════════════════════════════════════════════
PAYMENT_QR_PATH=./payment_qr.png
WECHAT_MERCHANT_ID=your-wechat-merchant-id
WECHAT_API_KEY=your-wechat-api-key

# ═══════════════════════════════════════════════════════════════
# 飞书配置（可选）
# ═══════════════════════════════════════════════════════════════
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_WEBHOOK_URL=your-feishu-webhook-url

# ═══════════════════════════════════════════════════════════════
# 硬件配置
# ═══════════════════════════════════════════════════════════════
DEVICE_ID=emulator-5554
ENABLE_LOCAL_VLM=false
MEMORY_THRESHOLD=0.8
PROCESS_CHECK_INTERVAL=30

# ═══════════════════════════════════════════════════════════════
# 监控配置
# ═══════════════════════════════════════════════════════════════
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=false
TRACING_ENDPOINT=http://localhost:4317

# ═══════════════════════════════════════════════════════════════
# 安全配置
# ═══════════════════════════════════════════════════════════════
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://localhost:8765
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ═══════════════════════════════════════════════════════════════
# 限流配置
# ═══════════════════════════════════════════════════════════════
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ═══════════════════════════════════════════════════════════════
# 缓存配置
# ═══════════════════════════════════════════════════════════════
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# ═══════════════════════════════════════════════════════════════
# 谈判配置
# ═══════════════════════════════════════════════════════════════
NEGOTIATION_MAX_ROUNDS=5
NEGOTIATION_TIMEOUT=300
NEGOTIATION_RETRY_MAX=3
