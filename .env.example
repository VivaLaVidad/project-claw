# .env.example - Project Claw v14.3
# 复制为 .env 并填入真实值。.env 已加入 .gitignore，绝不提交代码库。

# ══ DeepSeek LLM ══════════════════════════════════════
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=200
DEEPSEEK_TIMEOUT=15
DEEPSEEK_MAX_RETRIES=3

# ══ A2A 信令服务器 ═════════════════════════════════════
# Railway 部署时设为你的域名，本地开发留空用默认值
# A2A_SIGNALING_URL=wss://project-claw-production.up.railway.app
SIGNALING_HOST=127.0.0.1
SIGNALING_PORT=8765
SIGNALING_HTTP_SCHEME=http
SIGNALING_WS_SCHEME=ws

# ══ A2A 安全通信 ═══════════════════════════════════════
# 生产必须使用强随机字符串（openssl rand -hex 32）
A2A_SIGNING_SECRET=change-me-use-openssl-rand-hex-32
# Fernet 密钥（可选，留空则不加密 payload）
A2A_ENCRYPTION_KEY=

# ══ 商家 ID ════════════════════════════════════════════
A2A_MERCHANT_ID=box-001
A2A_MERCHANT_TAGS=

# ══ 内部接口鉴权 ═══════════════════════════════════════
# 内部服务间调用的 Bearer Token（空=开发模式放行）
INTERNAL_API_TOKEN=

# ══ Redis（幂等/画像/状态存储）════════════════════════
# 留空则降级到内存存储（开发/单机可用）
REDIS_URL=
# REDIS_URL=redis://localhost:6379/0
IDEMPOTENCY_TTL_SECONDS=300
PROFILE_TTL_SECONDS=86400

# ══ 日志 ═══════════════════════════════════════════════
LOG_LEVEL=INFO
LOG_FILE=claw.log
LOG_DIR=logs
SHOWCASE_EVENT_FILE=logs/showcase_events.jsonl

# ══ 支付 ═══════════════════════════════════════════════
PAYMENT_QR_PATH=./payment_qr.png

# ══ 谈判引擎 ═══════════════════════════════════════════
MATCH_ROUNDS=5
MATCH_THRESHOLD=90.0

# ══ 系统提示词（可自定义商家人设）════════════════════
SYSTEM_PROMPT=你是一个热情的店老板，回话简短接地气，叫人'兄弟'。

# ══ 本地记忆（B端菜单底价）══════════════════════════
LOCAL_MEMORY_ENABLED=true
LOCAL_MEMORY_DB_DIR=./claw_db
LOCAL_MEMORY_CSV=menu.csv
LOCAL_MEMORY_TOP_K=3

# ══ 生产标志（Railway 自动设置，本地留空）════════════
# RAILWAY_ENVIRONMENT=production
# PRODUCTION=1
