# Project Claw 环境变量配置样例
# 复制此文件为 .env 并填入真实值。请不要把真实密钥提交到仓库。

# ===== DeepSeek =====
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=10
DEEPSEEK_MAX_TOKENS=80
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_RETRIES=3

# ===== 飞书 =====
FEISHU_BOT_WEBHOOK=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=
FEISHU_AUTH_URL=https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal
FEISHU_BITABLE_URL=https://open.feishu.cn/open-apis/bitable/v1/apps
FEISHU_TOKEN_TIMEOUT=8

# ===== 支付执行 =====
PAYMENT_QR_PATH=./payment_qr.png

# ===== 日志 =====
LOG_LEVEL=INFO
LOG_FILE=lobster.log
LOG_DIR=logs
SHOWCASE_EVENT_FILE=logs/showcase_events.jsonl

# ===== 运行时接线 =====
A2A_SIGNALING_URL=ws://127.0.0.1:8765/ws/merchant/box-001
A2A_MERCHANT_ID=box-001
A2A_MERCHANT_TAGS=
A2A_SIGNING_SECRET=
A2A_ENCRYPTION_KEY=
AGENT_PROTOCOL_ONLY=false
INTERNAL_API_TOKEN=
REDIS_URL=
IDEMPOTENCY_TTL_SECONDS=300
EXECUTE_TRADE_SEND_TIMEOUT_SECONDS=4.0
PROFILE_TTL_SECONDS=86400
SIGNALING_HOST=127.0.0.1
SIGNALING_PORT=8765
SIGNALING_HTTP_SCHEME=http
SIGNALING_WS_SCHEME=ws
SIRI_HOST=0.0.0.0
SIRI_PORT=8010

# ===== OpenClaw（可选） =====
OPENCLAW_ENABLED=false
OPENCLAW_ENDPOINT=
OPENCLAW_API_KEY=
