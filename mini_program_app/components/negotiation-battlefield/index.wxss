.nb-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.96);
  overflow: hidden;
}

.nb-rain-wrap {
  position: absolute;
  inset: 0;
  opacity: 0.28;
}

.nb-rain-line {
  font-family: 'JetBrains Mono', 'Consolas', monospace;
  font-size: 18rpx;
  line-height: 1.4;
  color: #00ff9d;
  letter-spacing: 2rpx;
  white-space: nowrap;
  transform: translateY(-40rpx);
  animation: rainDrop 4.4s linear infinite;
}

@keyframes rainDrop {
  0% { transform: translateY(-40rpx); opacity: 0.1; }
  20% { opacity: 0.5; }
  100% { transform: translateY(120vh); opacity: 0; }
}

.nb-panel {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 8vh;
  bottom: 10vh;
  background: rgba(5, 18, 18, 0.56);
  backdrop-filter: blur(10px);
  border: 1rpx solid;
  border-image: linear-gradient(120deg, #00ff9d, #00d4ff, #00ff9d) 1;
  padding: 24rpx;
}

.nb-head {
  font-family: 'JetBrains Mono', 'Consolas', monospace;
  color: #00ff9d;
  font-size: 28rpx;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 0 12rpx rgba(0,255,157,0.6);
}

.nb-sides {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
  font-family: 'JetBrains Mono', 'Consolas', monospace;
}

.nb-side {
  max-width: 42%;
  border: 1rpx solid;
  padding: 10rpx 14rpx;
  clip-path: polygon(10rpx 0, 100% 0, 100% calc(100% - 10rpx), calc(100% - 10rpx) 100%, 0 100%, 0 10rpx);
}

.nb-side.left { color: #00d4ff; border-color: #00d4ff; }
.nb-side.right { color: #ff9f43; border-color: #ff9f43; text-align: right; }
.nb-vs { color: #00ff9d; font-size: 28rpx; }

.nb-log {
  height: calc(100% - 120rpx);
  border: 1rpx dashed rgba(0,212,255,0.36);
  padding: 12rpx;
  box-sizing: border-box;
}

.nb-line {
  font-family: 'JetBrains Mono', 'Consolas', monospace;
  font-size: 24rpx;
  line-height: 1.8;
  margin-bottom: 8rpx;
  white-space: pre-wrap;
}

.nb-line.left { color: #00d4ff; }
.nb-line.right { color: #ffad5c; }
.nb-line.system { color: #00ff9d; }

.nb-matched-flash {
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: matchFlash 0.9s ease-out;
}

.nb-matched-text {
  font-family: 'JetBrains Mono', 'Consolas', monospace;
  font-size: 120rpx;
  letter-spacing: 16rpx;
  color: #00ff9d;
  text-shadow: 0 0 30rpx rgba(0,255,157,0.95), 0 0 60rpx rgba(0,212,255,0.65);
}

@keyframes matchFlash {
  0% { opacity: 0; }
  20% { opacity: 1; }
  100% { opacity: 0; }
}
