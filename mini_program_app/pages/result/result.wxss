/* Project Claw v14.3 - pages/result/result.wxss */

.page {
  min-height: 100vh;
  background: #f0f4f8;
  padding: 0 0 60rpx;
}

/* ── Hero 区 ── */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
  margin-bottom: 24rpx;
}
.hero-ok   { background: linear-gradient(160deg, #0f172a 0%, #1e3a5f 100%); }
.hero-fail { background: linear-gradient(160deg, #1c0a0a 0%, #3b1212 100%); }

.hero-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  animation: popIn 0.4s cubic-bezier(0.34,1.56,0.64,1) both;
}
@keyframes popIn {
  from { transform: scale(0.3); opacity: 0; }
  to   { transform: scale(1);   opacity: 1; }
}
.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #f1f5f9;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}
.hero-sub {
  font-size: 26rpx;
  color: #94a3b8;
}

/* ── 详情卡片 ── */
.detail-card {
  background: #ffffff;
  border-radius: 24rpx;
  margin: 0 24rpx 20rpx;
  padding: 8rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}
.detail-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f1f5f9;
  gap: 20rpx;
}
.detail-row:last-child { border-bottom: none; }
.detail-key {
  font-size: 26rpx;
  color: #94a3b8;
  flex-shrink: 0;
  width: 140rpx;
}
.detail-val {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
  text-align: right;
  flex: 1;
  line-height: 1.5;
}
.detail-val.price {
  color: #dc2626;
  font-size: 38rpx;
  font-weight: 800;
}
.detail-val.reply {
  color: #475569;
  font-weight: 400;
  font-style: italic;
}
.detail-val.mono {
  font-size: 22rpx;
  color: #94a3b8;
  word-break: break-all;
}
.detail-val.err {
  color: #dc2626;
  font-weight: 400;
}

/* ── 设备回执卡片 ── */
.ack-card {
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.ack-ok      { background: #dcfce7; border: 2rpx solid #86efac; }
.ack-warn    { background: #fef3c7; border: 2rpx solid #fcd34d; }
.ack-pending { background: #f0f9ff; border: 2rpx solid #bae6fd; }
.ack-icon { font-size: 40rpx; flex-shrink: 0; }
.ack-text {
  font-size: 26rpx;
  color: #1e293b;
  line-height: 1.5;
  flex: 1;
}

/* ── 提示卡片 ── */
.tip-card {
  margin: 0 24rpx 24rpx;
  background: #fffbeb;
  border: 2rpx solid #fde68a;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
}
.tip-text {
  font-size: 24rpx;
  color: #92400e;
  line-height: 1.7;
}

/* ── 按钮组 ── */
.btn-group {
  display: flex;
  gap: 20rpx;
  margin: 0 24rpx 20rpx;
}
.btn-history {
  flex: 1;
  background: #f1f5f9;
  color: #475569;
  border-radius: 16rpx;
  font-size: 28rpx;
  height: 88rpx;
  border: 2rpx solid #e2e8f0;
}
.btn-home {
  flex: 2;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  height: 88rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(37,99,235,0.3);
}
.btn-share {
  margin: 0 24rpx;
  background: #ffffff;
  border: 2rpx solid #e2e8f0;
  color: #475569;
  border-radius: 16rpx;
  font-size: 28rpx;
  height: 80rpx;
}
