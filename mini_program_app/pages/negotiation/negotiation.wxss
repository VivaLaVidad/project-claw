.nego-page {
  min-height: 100vh;
  padding: 24rpx;
  background: transparent;
  box-sizing: border-box;
}

.card {
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #e6eaf2;
  box-shadow: 0 8rpx 26rpx rgba(23, 33, 61, 0.05);
}

.hero {
  padding: 24rpx;
}

.hero-title {
  font-size: 36rpx;
  color: #1f2937;
  font-weight: 700;
}

.hero-sub {
  margin-top: 8rpx;
  display: block;
  font-size: 24rpx;
  color: #6b7788;
}

.hero-status {
  margin-top: 12rpx;
  display: block;
  font-size: 25rpx;
  color: #2f6bff;
}

.section {
  margin-top: 18rpx;
  padding: 22rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 30rpx;
  color: #273244;
  font-weight: 600;
}

.section-tip {
  font-size: 22rpx;
  color: #8b95a5;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.filter-list {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.filter-chip {
  font-size: 22rpx;
  color: #5f6b7a;
  border: 1rpx solid #dce3f0;
  background: #f8f9fd;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.filter-chip.active {
  color: #2f6bff;
  border-color: #b8ccff;
  background: #edf2ff;
}

.export-link {
  font-size: 22rpx;
  color: #2f6bff;
}

.timeline {
  max-height: 560rpx;
  padding-right: 4rpx;
}

.timeline-item {
  padding: 14rpx;
  border-radius: 12rpx;
  background: #f8f9fd;
  border: 1rpx solid #e6eaf2;
  margin-bottom: 10rpx;
}

.timeline-tag {
  font-size: 20rpx;
  color: #8b95a5;
}

.timeline-text {
  margin-top: 6rpx;
  color: #344155;
  font-size: 25rpx;
  line-height: 1.6;
  display: block;
}

.timeline-item.cognition {
  border-left: 6rpx solid #8da9ff;
}

.timeline-item.strategy {
  border-left: 6rpx solid #6dbb9f;
}

.timeline-item.action {
  border-left: 6rpx solid #2f6bff;
}

.timeline-item.buyer {
  border-left: 6rpx solid #12a3ff;
  background: #eef8ff;
}

.timeline-item.merchant {
  border-left: 6rpx solid #ff9f43;
  background: #fff6eb;
}

.effect-tip {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 10rpx;
  font-size: 23rpx;
}

.effect-good {
  color: #2f9e72;
  background: #e9f8f1;
}

.effect-bad {
  color: #b7791f;
  background: #fff4e5;
}

.bid-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.bid-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  background: #f8f9fd;
  border: 1rpx solid #e6eaf2;
}

.bid-merchant {
  color: #3b4658;
  font-size: 24rpx;
}

.bid-price {
  color: #2f6bff;
  font-size: 28rpx;
  font-weight: 700;
}

.empty {
  text-align: center;
  color: #8b95a5;
  padding: 22rpx 0;
  font-size: 24rpx;
}

.seal-wrap {
  position: fixed;
  inset: 0;
  z-index: 9998;
  background: rgba(16, 22, 33, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.seal-card {
  width: 520rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 18rpx;
  text-align: center;
  box-shadow: 0 12rpx 34rpx rgba(30, 44, 72, 0.16);
}

.seal-title {
  color: #1f2937;
  font-size: 32rpx;
  font-weight: 700;
}

.seal-sub {
  margin-top: 10rpx;
  color: #6b7788;
  font-size: 24rpx;
  display: block;
}
