/* privacy.wxss */
.container {
  padding: 32rpx;
  background: #f8fafc;
  min-height: 100vh;
}
.header {
  text-align: center;
  padding: 48rpx 0 32rpx;
}
.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
}
.sub {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}
.section-body {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.8;
}
.footer {
  text-align: center;
  font-size: 22rpx;
  color: #cbd5e1;
  padding: 32rpx 0 64rpx;
}
