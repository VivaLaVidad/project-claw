<view class="page">
  <view class="card">
    <view class="title">收益概览</view>
    <view class="line"><text>今日营收</text><text>¥{{dashboard.today_revenue || 0}}</text></view>
    <view class="line"><text>今日订单</text><text>{{dashboard.today_order_count || 0}}</text></view>
    <view class="line"><text>待处理</text><text>{{dashboard.pending_count || 0}}</text></view>
  </view>

  <view class="card">
    <view class="title">账本钱包</view>
    <view class="line"><text>账本启用</text><text>{{wallet.ledger_enabled ? '是' : '否'}}</text></view>
    <view class="line"><text>余额</text><text>{{wallet.balance || 0}} {{wallet.currency_unit || 'token'}}</text></view>
    <view class="line"><text>冻结</text><text>{{wallet.is_frozen ? '是' : '否'}}</text></view>
    <view class="line"><text>可报价</text><text>{{wallet.can_quote ? '是' : '否'}}</text></view>
  </view>

  <button class="btn" loading="{{loading}}" bindtap="refresh">刷新</button>
</view>
