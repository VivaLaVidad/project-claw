## ⚡ 第二章：异步铁律（绝对强制）

### 2.1 IO 密集型操作（FastAPI、HTTP、数据库、缓存）
```python
# ✅ 正确：所有 IO 操作必须 async/await
async def create_intent(intent: A2A_TradeIntent) -> str:
    # FastAPI 路由
    async with httpx.AsyncClient() as client:
        response = await client.post(url, json=data)
    
    # Redis 操作
    await redis_client.set(key, value)
    
    # 数据库操作
    async with db.transaction():
        result = await db.execute(query)
    
    return result

# ❌ 错误：同步 IO 会阻塞事件循环
def create_intent(intent):
    response = requests.post(url, json=data)  # ❌ 阻塞
    redis_client.set(key, value)              # ❌ 阻塞
    db.execute(query)                         # ❌ 阻塞
```

### 2.2 CPU/视觉密集型操作（OCR、模型推理）
```python
# ✅ 正确：使用 asyncio.to_thread 或 ProcessPoolExecutor
import asyncio
from concurrent.futures import ProcessPoolExecutor

async def verify_payment_visual(image_path: str) -> dict:
    # 方式 1：asyncio.to_thread（推荐）
    result = await asyncio.to_thread(
        self._ocr_recognize,
        image_path
    )
    
    # 方式 2：ProcessPoolExecutor（CPU 密集）
    loop = asyncio.get_event_loop()
    with ProcessPoolExecutor() as executor:
        result = await loop.run_in_executor(
            executor,
            self._model_inference,
            image_path
        )
    
    return result

def _ocr_recognize(self, image_path: str) -> dict:
    """CPU 密集操作，在线程池中运行"""
    import paddleocr
    ocr = paddleocr.PaddleOCR()
    result = ocr.ocr(image_path)
    return self._parse_ocr_result(result)

# ❌ 错误：直接在 async 函数中调用 CPU 密集操作
async def verify_payment_visual(image_path: str):
    result = self._ocr_recognize(image_path)  # ❌ 阻塞事件循环
```

### 2.3 异步上下文管理
```python
# ✅ 正确：使用 async with 管理资源
async def negotiate_with_llm(prompt: str) -> str:
    async with httpx.AsyncClient() as client:
        response = await client.post(
            "https://api.deepseek.com/chat/completions",
            json={"messages": [{"role": "user", "content": prompt}]},
            timeout=30.0
        )
    return response.json()["choices"][0]["message"]["content"]

# ❌ 错误：资源泄漏
async def negotiate_with_llm(prompt: str):
    client = httpx.AsyncClient()
    response = await client.post(...)  # ❌ 如果异常，client 不会关闭
```

