## 💰 第三章：金融级容错（绝对强制）

### 3.1 幂等性保证（Idempotency Key）
```python
# ✅ 正确：所有状态变更操作必须幂等
async def execute_trade(
    trade_id: str,
    idempotency_key: str,  # 必须有
    amount: float,
    merchant_id: str,
) -> dict:
    # 步骤 1：检查幂等键
    existing = await db.execute(
        "SELECT * FROM trades WHERE idempotency_key = ?",
        (idempotency_key,)
    )
    
    if existing:
        # 已执行过，返回之前的结果
        return existing
    
    # 步骤 2：执行操作
    result = await self._do_execute_trade(trade_id, amount, merchant_id)
    
    # 步骤 3：记录幂等键
    await db.execute(
        "INSERT INTO trades (trade_id, idempotency_key, result) VALUES (?, ?, ?)",
        (trade_id, idempotency_key, json.dumps(result))
    )
    
    return result

# ❌ 错误：没有幂等性保证
async def execute_trade(trade_id, amount, merchant_id):
    # 如果网络中断，可能重复执行
    result = await self._do_execute_trade(trade_id, amount, merchant_id)
    return result
```

### 3.2 数据库排他锁（SELECT FOR UPDATE）
```python
# ✅ 正确：关键状态变更必须使用排他锁
async def update_trade_status(
    trade_id: str,
    new_status: str,
) -> bool:
    async with db.transaction():
        # 获取排他锁，防止并发修改
        trade = await db.execute(
            "SELECT * FROM trades WHERE trade_id = ? FOR UPDATE",
            (trade_id,)
        )
        
        if not trade:
            return False
        
        # 检查状态转移是否合法
        if not self._is_valid_transition(trade['status'], new_status):
            raise InvalidStateTransition()
        
        # 更新状态
        await db.execute(
            "UPDATE trades SET status = ? WHERE trade_id = ?",
            (new_status, trade_id)
        )
        
        return True

# ❌ 错误：没有排他锁，可能并发冲突
async def update_trade_status(trade_id, new_status):
    trade = await db.execute("SELECT * FROM trades WHERE trade_id = ?", (trade_id,))
    await db.execute("UPDATE trades SET status = ? WHERE trade_id = ?", (new_status, trade_id))
```

### 3.3 ClearingService 和 TradeCoordinator 的状态流转
```python
# ✅ 正确：账本和订单必须使用事务和幂等键
class ClearingService:
    """账本服务 - 金融级可靠性"""
    
    async def record_trade(
        self,
        trade_id: str,
        idempotency_key: str,
        merchant_id: str,
        client_id: str,
        amount: float,
        status: str,
    ) -> dict:
        """记录交易到账本"""
        async with self.db.transaction():
            # 检查幂等键
            existing = await self.db.execute(
                "SELECT * FROM clearing_ledger WHERE idempotency_key = ?",
                (idempotency_key,)
            )
            
            if existing:
                return existing
            
            # 获取排他锁
            await self.db.execute(
                "SELECT * FROM clearing_ledger WHERE trade_id = ? FOR UPDATE",
                (trade_id,)
            )
            
            # 记录到账本
            result = await self.db.execute(
                """
                INSERT INTO clearing_ledger 
                (trade_id, idempotency_key, merchant_id, client_id, amount, status, timestamp)
                VALUES (?, ?, ?, ?, ?, ?, ?)
                """,
                (trade_id, idempotency_key, merchant_id, client_id, amount, status, time.time())
            )
            
            return result

class TradeCoordinator:
    """订单协调器 - 金融级可靠性"""
    
    async def coordinate_trade(
        self,
        intent_id: str,
        idempotency_key: str,
        merchant_id: str,
        client_id: str,
        price: float,
    ) -> dict:
        """协调交易流程"""
        async with self.db.transaction():
            # 检查幂等键
            existing = await self.db.execute(
                "SELECT * FROM trade_orders WHERE idempotency_key = ?",
                (idempotency_key,)
            )
            
            if existing:
                return existing
            
            # 获取排他锁
            await self.db.execute(
                "SELECT * FROM trade_orders WHERE intent_id = ? FOR UPDATE",
                (intent_id,)
            )
            
            # 创建订单
            trade_id = f"trade-{uuid4()}"
            await self.db.execute(
                """
                INSERT INTO trade_orders 
                (trade_id, intent_id, idempotency_key, merchant_id, client_id, price, status)
                VALUES (?, ?, ?, ?, ?, ?, ?)
                """,
                (trade_id, intent_id, idempotency_key, merchant_id, client_id, price, "PENDING")
            )
            
            return {"trade_id": trade_id, "status": "PENDING"}
```

